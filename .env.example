# OpenRouter API Key (required for all agents)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Fleet API URL (used by agents for heartbeats)
FLEET_API_URL=http://fleet-api:8800

# Optional: n8n webhook for external heartbeat integration
N8N_HEARTBEAT_WEBHOOK=https://n8n.yourdomain.com/webhook/swarm-registry
